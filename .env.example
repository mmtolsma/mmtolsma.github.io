# Environment variables for this SvelteKit frontend.
# VITE_-prefixed vars are inlined into the client bundle at build time.
#
# URL of the Vercel serverless endpoint that the contact form POSTs to.
# Committed defaults live in .env.development and .env.production; override
# locally with .env.local or .env.development.local (both gitignored).
VITE_VERCEL_URL=
